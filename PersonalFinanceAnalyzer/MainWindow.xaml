<Window x:Class="PersonalFinanceAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PersonalFinanceAnalyzer.Views"
        Title="{Binding Title}" Height="750" Width="1050"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding SwitchToTransactionTabCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding SwitchToTransactionTabCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportToExcelCommand}"/>
        <KeyBinding Key="F5" Command="{Binding SyncNowCommand}"/>
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Menu Grid.Row="0" FontSize="14">
            <MenuItem Header="用户">
                <MenuItem Header="登录..." Command="{Binding LoginCommand}"/>
                <MenuItem Header="登出" Command="{Binding LogoutCommand}"
                          IsEnabled="{Binding IsLoggedIn}"/>
                <Separator/>
                <MenuItem Header="{Binding LoginStatus}" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="文件">
                <MenuItem Header="导入 CSV..." Command="{Binding ImportCsvCommand}"/>
                <MenuItem Header="导入微信账单..." Command="{Binding ImportWeChatBillCommand}"/>
                <Separator/>
                <MenuItem Header="导出 Excel..." Command="{Binding ExportToExcelCommand}"/>
                <Separator/>
                <MenuItem Header="备份数据..." Command="{Binding BackupDataCommand}"/>
                <MenuItem Header="恢复数据..." Command="{Binding RestoreDataCommand}"/>
                <Separator/>
                <MenuItem Header="退出" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="数据">
                <MenuItem Header="立即同步" Command="{Binding SyncNowCommand}"
                          IsEnabled="{Binding IsLoggedIn}"/>
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="关于..." Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Tab Content -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="概览">
                <views:DashboardView DataContext="{Binding Dashboard}"/>
            </TabItem>
            <TabItem Header="记录">
                <views:TransactionView DataContext="{Binding Transaction}"/>
            </TabItem>
            <TabItem Header="分析">
                <views:AnalysisView DataContext="{Binding Analysis}"/>
            </TabItem>
            <TabItem Header="预算">
                <views:BudgetView DataContext="{Binding Budget}"/>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#F0F0F0" Padding="10,4">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0">
                <TextBlock Text="{Binding LoginStatus}" FontSize="12" Foreground="#555"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding LastSyncTime}" FontSize="12" Foreground="#888" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SyncStatus}" FontSize="12" Foreground="#888" Margin="0,0,10,0"/>
                    <Button Content="同步" Command="{Binding SyncNowCommand}"
                            IsEnabled="{Binding IsLoggedIn}"
                            FontSize="11" Padding="8,1" Background="#1976D2" Foreground="White"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
