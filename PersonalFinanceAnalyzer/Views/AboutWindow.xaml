<Window x:Class="PersonalFinanceAnalyzer.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="个人收支趋势分析器" FontSize="20" FontWeight="Bold"
                   Foreground="#1976D2" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="版本 1.0.0" FontSize="13" Foreground="#888"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Separator Grid.Row="2" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock FontSize="14" Margin="0,0,0,5">
                <Run Text="作者："/><Run Text="ZhanJH" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock FontSize="13" Margin="0,0,0,3">
                <Run Text="邮箱："/><Run Text="magic_211_cs@126.com"/>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,5">
            <TextBlock FontSize="13" Margin="0,0,0,3">
                <Hyperlink NavigateUri="https://github.com/ZhanJHE" RequestNavigate="OnHyperlinkClick">
                    GitHub 主页：https://github.com/ZhanJHE
                </Hyperlink>
            </TextBlock>
            <TextBlock FontSize="13">
                <Hyperlink NavigateUri="https://github.com/ZhanJHE/Iregret_the_name_now" RequestNavigate="OnHyperlinkClick">
                    项目仓库：https://github.com/ZhanJHE/Iregret_the_name_now
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <Separator Grid.Row="5" Margin="0,10,0,15"/>

        <TextBlock Grid.Row="6" Text="课程项目作业 · WPF + ASP.NET Core"
                   FontSize="12" Foreground="#AAA" HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"/>
    </Grid>
</Window>
