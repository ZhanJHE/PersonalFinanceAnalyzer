<Window x:Class="PersonalFinanceAnalyzer.Views.EditTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑记录" Height="300" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Type -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="类型:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox x:Name="TypeCombo" Grid.Row="0" Grid.Column="1" Margin="5" Width="120"/>

        <!-- Category -->
        <TextBlock Grid.Row="0" Grid.Column="2" Text="类别:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox x:Name="CategoryCombo" Grid.Row="0" Grid.Column="3" Margin="5" Width="150"
                  DisplayMemberPath="Name"/>

        <!-- Amount -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="金额:" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="AmountBox" Grid.Row="1" Grid.Column="1" Margin="5" Width="120"/>

        <!-- Date -->
        <TextBlock Grid.Row="1" Grid.Column="2" Text="日期:" VerticalAlignment="Center" Margin="5"/>
        <DatePicker x:Name="DatePickerCtrl" Grid.Row="1" Grid.Column="3" Margin="5" Width="150"/>

        <!-- Note -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="备注:" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="NoteBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="5"/>

        <!-- Error -->
        <TextBlock x:Name="ErrorText" Grid.Row="3" Grid.ColumnSpan="4" Foreground="#D32F2F" Margin="5"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="SaveButton" Content="保存" Click="OnSaveClick"
                    Background="#1976D2" Foreground="White" Padding="30,8"
                    FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="取消" Click="OnCancelClick"
                    Background="#9E9E9E" Foreground="White" Padding="30,8"
                    FontSize="14" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
