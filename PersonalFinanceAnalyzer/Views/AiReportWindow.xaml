<Window x:Class="PersonalFinanceAnalyzer.Views.AiReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mdxaml="clr-namespace:MdXaml;assembly=MdXaml"
        Title="AI 分析报告" Height="550" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Foreground="#1976D2"/>
            <TextBlock x:Name="PeriodText" FontSize="13" Foreground="#888" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Markdown rendered content -->
        <Border Grid.Row="1" Background="#F9F9F9" CornerRadius="8" Padding="15">
            <mdxaml:MarkdownScrollViewer x:Name="MarkdownViewer"
                                          Markdown="{Binding ContentMarkdown}"
                                          FontSize="14"
                                          Background="Transparent"/>
        </Border>

        <!-- Close button -->
        <Button Grid.Row="2" Content="关闭" Click="OnCloseClick"
                Background="#1976D2" Foreground="White"
                Padding="30,10" FontSize="14" FontWeight="Bold"
                HorizontalAlignment="Right" Margin="0,15,0,0"/>
    </Grid>
</Window>
