<Window x:Class="PersonalFinanceAnalyzer.Views.ServerConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="服务器连接配置" Height="280" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Topmost="True">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Warning icon + text -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="⚠" FontSize="28" Foreground="#F57C00" Margin="0,0,10,0"/>
            <TextBlock FontSize="15" Foreground="#333" VerticalAlignment="Center">
                无法连接到服务器，请检查服务器地址或选择离线模式。
            </TextBlock>
        </StackPanel>

        <!-- Server URL -->
        <TextBlock Grid.Row="1" Text="服务器地址:" FontSize="13" Margin="0,0,0,5"/>
        <TextBox x:Name="ServerUrlBox" Grid.Row="2" FontSize="14" Padding="8"
                 Height="36" Margin="0,0,0,5"/>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="3" FontSize="13" Foreground="#D32F2F"
                   Margin="0,0,0,5"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RetryButton" Content="重试连接"
                    Click="OnRetryClick" Background="#1976D2" Foreground="White"
                    Padding="20,8" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="跳过（离线模式）"
                    Click="OnSkipClick" Background="#9E9E9E" Foreground="White"
                    Padding="15,8" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
