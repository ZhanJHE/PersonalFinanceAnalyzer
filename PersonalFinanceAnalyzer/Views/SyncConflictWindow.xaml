<Window x:Class="PersonalFinanceAnalyzer.Views.SyncConflictWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据同步" Height="500" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Mode selection -->
        <Border Grid.Row="0" Background="#FFF3E0" CornerRadius="6" Padding="14" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontSize="15" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,10">
                    ⚠ 本地与云端数据不一致，请选择处理方式
                </TextBlock>
                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <RadioButton x:Name="RadioKeepLocal" Content="保留本地数据（用本地覆盖云端）" GroupName="SyncMode" IsChecked="True"
                                 FontSize="13" Margin="0,0,0,5"/>
                    <RadioButton x:Name="RadioKeepCloud" Content="保留云端数据（用云端覆盖本地）" GroupName="SyncMode"
                                 FontSize="13" Margin="0,0,0,5"/>
                    <RadioButton x:Name="RadioPerItem" Content="逐条处理（查看每条记录的差异并选择）" GroupName="SyncMode"
                                 FontSize="13"/>
                </StackPanel>
                <TextBlock x:Name="DateInfoText" Grid.Row="2" FontSize="12" Foreground="#888" Margin="0,5,0,0"/>
            </Grid>
        </Border>

        <!-- Per-item conflict list (only visible in per-item mode) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Visibility="Collapsed" x:Name="ConflictScrollViewer">
            <ItemsControl x:Name="ConflictList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F9F9F9" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="13" FontWeight="Bold">
                                    <Run Text="{Binding Local.TransactionDate}"/>
                                    <Run Text="{Binding Local.CategoryName}"/>
                                    <Run Text="{Binding Local.Amount, StringFormat={}¥{0:N2}}"/>
                                </TextBlock>

                                <Border Grid.Row="1" Grid.Column="0" Background="#E3F2FD" CornerRadius="4" Padding="8" Margin="0,5,3,0">
                                    <StackPanel>
                                        <TextBlock Text="本地版本" FontWeight="Bold" Foreground="#1565C0"/>
                                        <TextBlock Text="{Binding Local.UpdatedAt, StringFormat={}修改时间：{0:yyyy-MM-dd HH:mm}}" FontSize="12" Foreground="#555"/>
                                        <TextBlock Text="{Binding Local.Note, StringFormat={}备注：{0}}" FontSize="12" Foreground="#555"/>
                                        <RadioButton x:Name="LocalRadio" Content="使用本地" GroupName="{Binding Local.Id}" IsChecked="True"
                                                     FontSize="12" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Background="#FFF3E0" CornerRadius="4" Padding="8" Margin="3,5,0,0">
                                    <StackPanel>
                                        <TextBlock Text="云端版本" FontWeight="Bold" Foreground="#E65100"/>
                                        <TextBlock Text="{Binding Cloud.UpdatedAt, StringFormat={}修改时间：{0:yyyy-MM-dd HH:mm}}" FontSize="12" Foreground="#555"/>
                                        <TextBlock Text="{Binding Cloud.Note, StringFormat={}备注：{0}}" FontSize="12" Foreground="#555"/>
                                        <RadioButton x:Name="CloudRadio" Content="使用云端" GroupName="{Binding Local.Id}"
                                                     FontSize="12" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="取消" Click="OnCancelClick"
                    Background="#9E9E9E" Foreground="White" Padding="15,8" FontSize="13" Margin="0,0,10,0"/>
            <Button x:Name="ConfirmButton" Content="确定" Click="OnConfirmClick"
                    Background="#1976D2" Foreground="White" Padding="25,8" FontSize="14" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
