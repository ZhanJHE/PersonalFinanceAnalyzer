<Window x:Class="PersonalFinanceAnalyzer.Views.WeChatImportGuide"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="微信账单导入指南" Height="640" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable guide content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="25,20">
            <StackPanel>

                <TextBlock FontSize="20" FontWeight="Bold" Text="微信账单导入指南"
                           Foreground="#1976D2" Margin="0,0,0,20"/>

                <!-- Step 1 -->
                <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#333">
                            <Run Text="第 1 步"/><Run Text="：在微信中导出账单" Foreground="#1976D2" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Margin="0,10,0,0" FontSize="14" LineHeight="22">
                            打开微信 App，按以下路径操作：<LineBreak/>
                            <Run FontWeight="Bold" Foreground="#555">我</Run>
                            <Run Foreground="#999"> → </Run>
                            <Run FontWeight="Bold" Foreground="#555">服务</Run>
                            <Run Foreground="#999"> → </Run>
                            <Run FontWeight="Bold" Foreground="#555">钱包</Run>
                            <Run Foreground="#999"> → </Run>
                            <Run FontWeight="Bold" Foreground="#555">账单</Run>
                            <LineBreak/>
                            点右上角 <Run FontWeight="Bold" Foreground="#D32F2F">「...」</Run>
                            <Run Foreground="#999"> → </Run>
                            <Run FontWeight="Bold" Foreground="#555">账单下载</Run>
                            <LineBreak/>
                            选择 <Run FontWeight="Bold" Foreground="#D32F2F">「用作个人对账」</Run>
                            <LineBreak/>
                            选择时间范围 → 点击 <Run FontWeight="Bold" Foreground="#555">「下一步」</Run>
                            <LineBreak/>
                            填写邮箱（推荐）或直接下载到手机
                        </TextBlock>
                        <Border Background="#FFF3E0" CornerRadius="4" Padding="10" Margin="0,10,0,0">
                            <TextBlock FontSize="13" Foreground="#E65100">
                                ⚠ 记得选择「用作个人对账」，不是「用于微信团队」。
                                导出的文件格式为 xlsx（Excel 格式）。
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 2 -->
                <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#333">
                            <Run Text="第 2 步"/><Run Text="：把文件传到电脑上" Foreground="#1976D2" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Margin="0,10,0,0" FontSize="14" LineHeight="22">
                            如果选择邮箱发送：登录邮箱下载附件（xlsx 格式）<LineBreak/>
                            如果下载到手机：通过数据线 / 微信文件传输助手 / 网盘 传到电脑<LineBreak/>
                            <Run FontWeight="Bold">文件通常是「微信支付账单流水文件_xxxx.xlsx」</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Step 3 -->
                <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#333">
                            <Run Text="第 3 步"/><Run Text="：在本程序中导入" Foreground="#1976D2" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Margin="0,10,0,0" FontSize="14" LineHeight="22">
                            点击本窗口底部的 <Run FontWeight="Bold" Foreground="#1976D2">「选择文件并导入」</Run> 按钮<LineBreak/>
                            选择刚才的 xlsx 文件<LineBreak/>
                            程序会自动识别为微信账单并解析<LineBreak/>
                            导入完成后会显示结果（成功/跳过/错误数量）
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Notes -->
                <Border Background="#E3F2FD" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="#1565C0">💡 小贴士</TextBlock>
                        <TextBlock Margin="0,8,0,0" FontSize="13" Foreground="#333" LineHeight="20">
                            • 微信账单中的交易对方会自动匹配到已有类别（如"美团"→餐饮），匹配不到的会归入默认类别<LineBreak/>
                            • 导入后建议去「记录」页检查一下类别是否正确<LineBreak/>
                            • 支持同时导入多份账单（重复导入会自动按更新时间覆盖）
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar with import button -->
        <Border Grid.Row="1" Background="#FAFAFA" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="13" Foreground="#666"
                           Margin="0,0,15,0"/>
                <Button x:Name="ImportButton" Content="选择文件并导入"
                        Click="OnImportClick"
                        Background="#1976D2" Foreground="White"
                        Padding="25,8" FontSize="14" FontWeight="Bold"/>
                <Button Content="关闭" Click="OnCloseClick"
                        Background="#9E9E9E" Foreground="White"
                        Padding="20,8" FontSize="14" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
