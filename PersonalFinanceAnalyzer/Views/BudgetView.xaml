<UserControl x:Class="PersonalFinanceAnalyzer.Views.BudgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Set Budget Form -->
        <GroupBox Grid.Row="0" Header="设置月度预算" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="类别:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox ItemsSource="{Binding ExpenseCategories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="Name" Width="150" Margin="5"/>
                <TextBlock Text="预算上限(元):" VerticalAlignment="Center" Margin="5"/>
                <TextBox Text="{Binding NewLimit}" Width="120" Margin="5"/>
                <Button Content="设置" Command="{Binding SetBudgetCommand}"
                        Background="#1976D2" Foreground="White"
                        Padding="15,5" FontWeight="Bold" Margin="5"/>
            </StackPanel>
        </GroupBox>

        <!-- Budget List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Budgets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding CategoryName, Converter={StaticResource CategoryColor}, ConverterParameter=0.2}"
                                CornerRadius="8" Padding="15" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!-- Category name -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding CategoryName}"
                                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>

                                <!-- Spent / Limit -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Spent, StringFormat={}已花 ¥{0:N2}}" FontSize="14"
                                               Foreground="#C62828" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding MonthlyLimit, StringFormat={}/ ¥{0:N2}}" FontSize="14"
                                               Foreground="#555"/>
                                    <TextBlock Text="{Binding Percentage, StringFormat={}（{0}%）}" FontSize="13"
                                               Foreground="#888" Margin="5,0,0,0"/>
                                </StackPanel>

                                <!-- Progress text / over-budget warning -->
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,3,0,0">
                                    <Border CornerRadius="3" Padding="6,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="12" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="预算充足 ✓"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                            <Setter Property="Text" Value="⚠ 已超预算"/>
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding MonthlyLimit}" Value="0">
                                                            <Setter Property="Text" Value="未设置预算"/>
                                                            <Setter Property="Foreground" Value="#9E9E9E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>

                                <!-- Delete button -->
                                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                        Content="清除" VerticalAlignment="Center"
                                        Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.DeleteBudgetCommand}"
                                        CommandParameter="{Binding}"
                                        Background="#F44336" Foreground="White"
                                        Padding="10,5" FontSize="12"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
